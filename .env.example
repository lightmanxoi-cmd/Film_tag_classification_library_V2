# ===========================================
# 视频标签分类系统配置文件示例
# ===========================================
# 复制此文件为 .env 并修改配置值
# cp .env.example .env
# ===========================================

# ===========================================
# 核心配置（必须设置）
# ===========================================

# 视频文件存储路径（必须设置）
# Windows 示例: VIDEO_BASE_PATH=F:\Videos
# Linux/Mac 示例: VIDEO_BASE_PATH=/data/videos
VIDEO_BASE_PATH=F:\666

# 应用密钥（生产环境必须设置）
# 用于会话签名和CSRF保护
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-me-in-production

# 会话密钥（推荐设置，优先级高于SECRET_KEY）
# 用于Flask会话加密，如果未设置则使用SECRET_KEY
# 生产环境建议单独设置此变量，与会话签名密钥分离
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=your-session-secret-change-me-in-production

# ===========================================
# 认证配置
# ===========================================

# 初始默认密码（可选，首次运行时设置）
# 如果不设置，首次运行时会提示设置密码
# 生产环境建议设置复杂密码
DEFAULT_PASSWORD=your-secure-password

# 会话超时时间（秒），默认 1800（30分钟）
INACTIVITY_TIMEOUT=1800

# ===========================================
# 数据库配置
# ===========================================

# 数据库连接URL（可选，默认使用SQLite）
# SQLite: DATABASE_URL=sqlite:///./video_library.db
# PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/dbname
# MySQL: DATABASE_URL=mysql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./video_library.db

# 是否打印SQL语句（调试用，生产环境建议关闭）
DATABASE_ECHO=false

# ===========================================
# 系统配置（video_tag_system 模块）
# ===========================================

# 数据库连接URL（系统模块）
# 注意：应与 DATABASE_URL 保持一致，使用同一个数据库
VTS_DATABASE_URL=sqlite:///./video_library.db

# 是否打印SQL语句
VTS_DATABASE_ECHO=false

# 备份目录
VTS_BACKUP_DIR=./backups

# 最大备份数量
VTS_MAX_BACKUP_COUNT=10

# 批量操作批次大小
VTS_BATCH_SIZE=100

# 日志级别
VTS_LOG_LEVEL=INFO

# ===========================================
# 缓存配置
# ===========================================

# 缓存清理间隔（秒），默认 300（5分钟）
CACHE_CLEANUP_INTERVAL=300

# ===========================================
# CORS 跨域配置
# ===========================================

# 允许跨域请求的来源（多个用逗号分隔）
# 开发环境: * (允许所有来源)
# 生产环境: https://your-frontend.com,https://admin.your-frontend.com
CORS_ORIGINS=*

# ===========================================
# Flask 环境配置
# ===========================================

# 运行环境: development, production, testing
FLASK_ENV=development

# 调试模式（生产环境必须关闭）
FLASK_DEBUG=false

# ===========================================
# 安全建议
# ===========================================
# 1. 生产环境必须设置 SECRET_KEY
# 2. 生产环境必须设置 VIDEO_BASE_PATH
# 3. 生产环境建议设置 SESSION_SECRET（或使用 SECRET_KEY 作为会话密钥）
# 4. 生产环境建议设置 DEFAULT_PASSWORD 或首次运行后立即修改
# 5. 不要将 .env 文件提交到版本控制系统
# 6. 定期更换密码和密钥
# 7. .auth_config.json 仅存储密码哈希，会话密钥已迁移至环境变量
