# 视频标签管理系统 - 生产环境配置示例
# 复制此文件为 .env 并根据实际情况修改

# ============================================
# 服务器配置
# ============================================
# 服务器监听地址 (0.0.0.0 表示监听所有网卡)
HOST=0.0.0.0

# 服务器监听端口
PORT=5000

# 工作线程数 (建议: CPU核心数 × 2)
WORKER_THREADS=4

# ============================================
# 视频路径配置
# ============================================
# 视频文件根目录 (请修改为实际路径)
VIDEO_BASE_PATH=F:\666

# ============================================
# 数据库配置
# ============================================
# 数据库URL (SQLite)
DATABASE_URL=sqlite:///./video_library.db

# 是否启用SQL语句日志 (生产环境建议关闭)
DATABASE_ECHO=False

# ============================================
# 安全配置
# ============================================
# Flask密钥 (生产环境必须修改!)
# 可以使用以下命令生成: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# 会话超时时间 (秒)
SESSION_TIMEOUT=1800

# 是否启用安全Cookie (HTTPS环境下启用)
SESSION_COOKIE_SECURE=False

# 是否启用HttpOnly Cookie
SESSION_COOKIE_HTTPONLY=True

# Cookie SameSite策略
SESSION_COOKIE_SAMESITE=Lax

# ============================================
# 性能配置
# ============================================
# 缩略图生成线程数
THUMBNAIL_WORKERS=2

# 是否启用GIF预览生成
ENABLE_GIF_PREVIEW=True

# 最大上传文件大小 (字节)
MAX_CONTENT_LENGTH=1073741824

# ==========================================
# 日志配置
# ==========================================
# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/app.log

# 是否输出到控制台
LOG_TO_CONSOLE=True
